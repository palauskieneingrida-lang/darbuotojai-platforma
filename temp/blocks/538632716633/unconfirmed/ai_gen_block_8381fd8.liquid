{% doc %}
  @prompt
    Create a full psy trance psychedelic visual theme for the hero section. Include: vibrant neon colors (magenta, cyan, lime green, electric purple), animated gradient backgrounds that shift and pulse, fractal or mandala-inspired decorative elements, glowing text with rainbow or aurora color effects, trippy geometric patterns or sacred geometry as background overlays, smooth looping CSS animations (rotating, pulsing, color-shifting), and an overall hypnotic psychedelic festival aesthetic. Dark background with intense neon glow effects throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-psytrance-hero-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height }}vh;
    overflow: hidden;
    background: #000000;
  }

  .ai-psytrance-hero__bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-psytrance-hero__gradient-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      45deg,
      {{ block.settings.gradient_color_1 }},
      {{ block.settings.gradient_color_2 }},
      {{ block.settings.gradient_color_3 }},
      {{ block.settings.gradient_color_4 }}
    );
    background-size: 400% 400%;
    opacity: {{ block.settings.gradient_opacity }};
  }

  .ai-psytrance-hero__mandala-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    opacity: {{ block.settings.pattern_opacity }};
    pointer-events: none;
  }

  .ai-psytrance-hero__mandala-svg-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
  }

  .ai-psytrance-hero__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.hero_height }}vh;
    padding: 60px 20px;
    text-align: center;
  }

  .ai-psytrance-hero__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 20px;
    background: linear-gradient(
      90deg,
      {{ block.settings.text_color_1 }},
      {{ block.settings.text_color_2 }},
      {{ block.settings.text_color_3 }},
      {{ block.settings.text_color_1 }}
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 20px {{ block.settings.text_glow_color }};
    filter: drop-shadow(0 0 30px {{ block.settings.text_glow_color }});
  }

  .ai-psytrance-hero__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0 0 40px;
    color: {{ block.settings.subtitle_color }};
    text-shadow: 0 0 15px {{ block.settings.subtitle_glow_color }};
    max-width: 800px;
  }

  .ai-psytrance-hero__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 18px 40px;
    background: linear-gradient(
      135deg,
      {{ block.settings.button_color_1 }},
      {{ block.settings.button_color_2 }}
    );
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    box-shadow: 0 0 30px {{ block.settings.button_glow_color }};
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border_color }};
  }

  .ai-psytrance-hero__button-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
    box-shadow: 0 0 50px {{ block.settings.button_glow_color }};
  }

  .ai-psytrance-hero__geometric-{{ ai_gen_id }} {
    position: absolute;
    border: 2px solid {{ block.settings.geometric_color }};
    opacity: {{ block.settings.geometric_opacity }};
    pointer-events: none;
  }

  .ai-psytrance-hero__geometric-1-{{ ai_gen_id }} {
    top: 10%;
    left: 10%;
    width: 150px;
    height: 150px;
    border-radius: 50%;
  }

  .ai-psytrance-hero__geometric-2-{{ ai_gen_id }} {
    top: 60%;
    right: 15%;
    width: 100px;
    height: 100px;
    transform: rotate(45deg);
  }

  .ai-psytrance-hero__geometric-3-{{ ai_gen_id }} {
    bottom: 15%;
    left: 20%;
    width: 120px;
    height: 120px;
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
  }

  .ai-psytrance-hero__geometric-4-{{ ai_gen_id }} {
    top: 20%;
    right: 25%;
    width: 80px;
    height: 80px;
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
  }

  {% if block.settings.enable_animations %}
    @keyframes ai-psytrance-gradient-shift-{{ ai_gen_id }} {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }

    @keyframes ai-psytrance-text-rainbow-{{ ai_gen_id }} {
      0% {
        background-position: 0% center;
      }
      100% {
        background-position: 200% center;
      }
    }

    @keyframes ai-psytrance-rotate-{{ ai_gen_id }} {
      0% {
        transform: translate(-50%, -50%) rotate(0deg);
      }
      100% {
        transform: translate(-50%, -50%) rotate(360deg);
      }
    }

    @keyframes ai-psytrance-pulse-{{ ai_gen_id }} {
      0%, 100% {
        transform: scale(1);
        opacity: {{ block.settings.geometric_opacity }};
      }
      50% {
        transform: scale(1.1);
        opacity: {{ block.settings.geometric_opacity | times: 1.5 | at_most: 1 }};
      }
    }

    @keyframes ai-psytrance-float-1-{{ ai_gen_id }} {
      0%, 100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(-20px) rotate(10deg);
      }
    }

    @keyframes ai-psytrance-float-2-{{ ai_gen_id }} {
      0%, 100% {
        transform: translateY(0) rotate(45deg);
      }
      50% {
        transform: translateY(20px) rotate(55deg);
      }
    }

    @keyframes ai-psytrance-float-3-{{ ai_gen_id }} {
      0%, 100% {
        transform: translateY(0) scale(1);
      }
      50% {
        transform: translateY(-15px) scale(1.05);
      }
    }

    @keyframes ai-psytrance-float-4-{{ ai_gen_id }} {
      0%, 100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(15px) rotate(-10deg);
      }
    }

    .ai-psytrance-hero__gradient-{{ ai_gen_id }} {
      animation: ai-psytrance-gradient-shift-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease infinite;
    }

    .ai-psytrance-hero__title-{{ ai_gen_id }} {
      animation: ai-psytrance-text-rainbow-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 1.5 }}s linear infinite;
    }

    .ai-psytrance-hero__mandala-{{ ai_gen_id }} {
      animation: ai-psytrance-rotate-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 4 }}s linear infinite;
    }

    .ai-psytrance-hero__geometric-1-{{ ai_gen_id }} {
      animation: ai-psytrance-float-1-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 2 }}s ease-in-out infinite,
                 ai-psytrance-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
    }

    .ai-psytrance-hero__geometric-2-{{ ai_gen_id }} {
      animation: ai-psytrance-float-2-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 2.5 }}s ease-in-out infinite,
                 ai-psytrance-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 1.2 }}s ease-in-out infinite;
    }

    .ai-psytrance-hero__geometric-3-{{ ai_gen_id }} {
      animation: ai-psytrance-float-3-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 3 }}s ease-in-out infinite,
                 ai-psytrance-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 1.5 }}s ease-in-out infinite;
    }

    .ai-psytrance-hero__geometric-4-{{ ai_gen_id }} {
      animation: ai-psytrance-float-4-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 2.2 }}s ease-in-out infinite,
                 ai-psytrance-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed | times: 1.3 }}s ease-in-out infinite;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-psytrance-hero__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.5 }}px;
    }

    .ai-psytrance-hero__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .ai-psytrance-hero__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
      padding: 14px 30px;
    }

    .ai-psytrance-hero__geometric-1-{{ ai_gen_id }},
    .ai-psytrance-hero__geometric-2-{{ ai_gen_id }},
    .ai-psytrance-hero__geometric-3-{{ ai_gen_id }},
    .ai-psytrance-hero__geometric-4-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<psy-trance-hero-{{ ai_gen_id }} class="ai-psytrance-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-psytrance-hero__bg-{{ ai_gen_id }}">
    <div class="ai-psytrance-hero__gradient-{{ ai_gen_id }}"></div>
    
    <div class="ai-psytrance-hero__mandala-{{ ai_gen_id }}">
      <svg class="ai-psytrance-hero__mandala-svg-{{ ai_gen_id }}" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="mandala-gradient-{{ ai_gen_id }}" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:{{ block.settings.mandala_color_1 }};stop-opacity:1" />
            <stop offset="50%" style="stop-color:{{ block.settings.mandala_color_2 }};stop-opacity:1" />
            <stop offset="100%" style="stop-color:{{ block.settings.mandala_color_3 }};stop-opacity:1" />
          </linearGradient>
        </defs>
        
        <g transform="translate(100,100)">
          {% for i in (0..11) %}
            {% assign angle = i | times: 30 %}
            <g transform="rotate({{ angle }})">
              <circle cx="0" cy="-60" r="8" fill="url(#mandala-gradient-{{ ai_gen_id }})" />
              <circle cx="0" cy="-40" r="6" fill="url(#mandala-gradient-{{ ai_gen_id }})" />
              <circle cx="0" cy="-20" r="4" fill="url(#mandala-gradient-{{ ai_gen_id }})" />
              <line x1="0" y1="0" x2="0" y2="-70" stroke="url(#mandala-gradient-{{ ai_gen_id }})" stroke-width="1" />
            </g>
          {% endfor %}
          
          {% for i in (0..5) %}
            {% assign angle = i | times: 60 %}
            <g transform="rotate({{ angle }})">
              <polygon points="0,-80 5,-70 0,-60 -5,-70" fill="url(#mandala-gradient-{{ ai_gen_id }})" />
            </g>
          {% endfor %}
          
          <circle cx="0" cy="0" r="70" fill="none" stroke="url(#mandala-gradient-{{ ai_gen_id }})" stroke-width="2" />
          <circle cx="0" cy="0" r="50" fill="none" stroke="url(#mandala-gradient-{{ ai_gen_id }})" stroke-width="1.5" />
          <circle cx="0" cy="0" r="30" fill="none" stroke="url(#mandala-gradient-{{ ai_gen_id }})" stroke-width="1" />
          <circle cx="0" cy="0" r="10" fill="url(#mandala-gradient-{{ ai_gen_id }})" />
        </g>
      </svg>
    </div>

    <div class="ai-psytrance-hero__geometric-1-{{ ai_gen_id }} ai-psytrance-hero__geometric-{{ ai_gen_id }}"></div>
    <div class="ai-psytrance-hero__geometric-2-{{ ai_gen_id }} ai-psytrance-hero__geometric-{{ ai_gen_id }}"></div>
    <div class="ai-psytrance-hero__geometric-3-{{ ai_gen_id }} ai-psytrance-hero__geometric-{{ ai_gen_id }}"></div>
    <div class="ai-psytrance-hero__geometric-4-{{ ai_gen_id }} ai-psytrance-hero__geometric-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-psytrance-hero__content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h1 class="ai-psytrance-hero__title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}

    {% if block.settings.subtitle != blank %}
      <p class="ai-psytrance-hero__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-psytrance-hero__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</psy-trance-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class PsyTranceHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupInteractivity();
      }

      setupInteractivity() {
        const button = this.querySelector('.ai-psytrance-hero__button-{{ ai_gen_id }}');
        if (button) {
          button.addEventListener('mouseenter', function() {
            this.style.transform = 'scale(1.1)';
          });
          button.addEventListener('mouseleave', function() {
            this.style.transform = 'scale(1)';
          });
        }
      }
    }

    customElements.define('psy-trance-hero-{{ ai_gen_id }}', PsyTranceHero{{ ai_gen_id }});
  })();
</script>

