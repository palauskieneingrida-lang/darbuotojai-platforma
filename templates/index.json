    "custom_liquid_xVzfYR": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"lt\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>DRIVE // Cyberpunk Shop</title>\n    <!-- Three.js 3D grafikai -->\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\n    <!-- Google Fonts neoniniam stiliui -->\n    <link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        :root {\n            --neon-pink: #ff007f;\n            --neon-cyan: #00f3ff;\n            --neon-purple: #9400d3;\n            --dark-bg: #05050a;\n            --rgb-speed: 6s;\n        }\n\n        body, html {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            overflow-x: hidden;\n            background-color: var(--dark-bg);\n            font-family: 'Rajdhani', sans-serif;\n            color: #fff;\n        }\n\n        /* 3D Fonas */\n        #canvas-container {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100vh;\n            z-index: -1;\n        }\n\n        /* RGB Skenavimo Linija (Cyberpunk efektas) */\n        body::before {\n            content: \" \";\n            display: block;\n            position: fixed;\n            top: 0; left: 0; bottom: 0; right: 0;\n            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n            z-index: 99;\n            background-size: 100% 2px, 3px 100%;\n            pointer-events: none;\n        }\n\n        /* Headeris / Navigacija */\n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: 20px 50px;\n            background: rgba(5, 5, 10, 0.8);\n            backdrop-filter: blur(10px);\n            border-bottom: 2px solid var(--neon-pink);\n            box-shadow: 0 0 20px var(--neon-pink);\n        }\n\n        .logo {\n            font-family: 'Orbitron', sans-serif;\n            font-size: 2rem;\n            font-weight: 900;\n            text-transform: uppercase;\n            letter-spacing: 5px;\n            color: #fff;\n            text-shadow: 0 0 10px var(--neon-cyan), 0 0 20px var(--neon-cyan);\n            animation: rgb-text var(--rgb-speed) infinite linear;\n        }\n\n        /* Hero Sekcija */\n        .hero {\n            height: 80vh;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            padding: 0 20px;\n        }\n\n        .hero h1 {\n            font-family: 'Orbitron', sans-serif;\n            font-size: 5rem;\n            text-transform: uppercase;\n            margin: 0;\n            letter-spacing: 10px;\n            color: #fff;\n            text-shadow: 0 0 20px var(--neon-pink);\n        }\n\n        .hero p {\n            font-size: 1.5rem;\n            text-transform: uppercase;\n            letter-spacing: 3px;\n            color: var(--neon-cyan);\n            margin: 20px 0;\n            text-shadow: 0 0 10px var(--neon-cyan);\n        }\n\n        /* RGB Mygtukas */\n        .neon-btn {\n            font-family: 'Orbitron', sans-serif;\n            font-size: 1.2rem;\n            padding: 15px 40px;\n            border: 2px solid var(--neon-cyan);\n            background: transparent;\n            color: #fff;\n            text-transform: uppercase;\n            cursor: pointer;\n            font-weight: bold;\n            letter-spacing: 2px;\n            position: relative;\n            transition: 0.3s;\n            overflow: hidden;\n            box-shadow: 0 0 15px rgba(0, 243, 255, 0.4);\n        }\n\n        .neon-btn:hover {\n            background: var(--neon-cyan);\n            color: var(--dark-bg);\n            box-shadow: 0 0 30px var(--neon-cyan), 0 0 50px var(--neon-cyan);\n            transform: scale(1.05);\n        }\n\n        /* Produktų Grid'as */\n        .products-section {\n            padding: 100px 50px;\n            background: rgba(5, 5, 10, 0.85);\n            backdrop-filter: blur(5px);\n        }\n\n        .section-title {\n            font-family: 'Orbitron', sans-serif;\n            font-size: 3rem;\n            text-align: center;\n            margin-bottom: 50px;\n            text-transform: uppercase;\n            color: #fff;\n            text-shadow: 0 0 15px var(--neon-purple);\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 40px;\n            max-width: 1200px;\n            margin: 0 auto;\n        }\n\n        /* Cyberpunk Produkto Kortelė */\n        .card {\n            background: rgba(20, 20, 35, 0.6);\n            border: 1px solid rgba(255, 0, 127, 0.3);\n            border-radius: 4px;\n            padding: 20px;\n            text-align: center;\n            position: relative;\n            transition: 0.4s ease;\n            backdrop-filter: blur(10px);\n        }\n\n        .card:hover {\n            border-color: var(--neon-pink);\n            box-shadow: 0 0 25px rgba(255, 0, 127, 0.6), inset 0 0 15px rgba(255, 0, 127, 0.2);\n            transform: translateY(-10px);\n        }\n\n        .card img {\n            width: 100%;\n            height: 250px;\n            object-fit: cover;\n            border-bottom: 2px solid var(--neon-cyan);\n            margin-bottom: 15px;\n        }\n\n        .card h3 {\n            font-family: 'Orbitron', sans-serif;\n            font-size: 1.6rem;\n            margin: 10px 0;\n            letter-spacing: 1px;\n        }\n\n        .price {\n            font-size: 1.4rem;\n            color: var(--neon-cyan);\n            font-weight: bold;\n            margin-bottom: 15px;\n            text-shadow: 0 0 5px var(--neon-cyan);\n        }\n\n        /* RGB Animacijos */\n        @keyframes rgb-text {\n            0% { text-shadow: 0 0 10px var(--neon-cyan); }\n            33% { text-shadow: 0 0 10px var(--neon-pink); }\n            66% { text-shadow: 0 0 10px var(--neon-purple); }\n            100% { text-shadow: 0 0 10px var(--neon-cyan); }\n        }\n\n        @media (max-width: 768px) {\n            .hero h1 { font-size: 3rem; }\n            header { padding: 20px; }\n        }\n    </style>\n</head>\n<body>\n\n    <!-- 3D Three.js Drobulė Fone -->\n    <div id=\"canvas-container\"></div>\n\n    <!-- Navigacija -->\n    <header>\n        <div class=\"logo\">DRIVE //</div>\n        <button class=\"neon-btn\" style=\"padding: 10px 20px; font-size: 0.9rem;\">Krepšelis (0)</button>\n    </header>\n\n    <!-- Hero Sekcija -->\n    <section class=\"hero\">\n        <h1>NIGHT DRIVE</h1>\n        <p>Cyberpunk stiliaus aksesuarai & apranga naktiniams klajūnams</p>\n        <button class=\"neon-btn\">Pirkti Kolekciją</button>\n    </section>\n\n    <!-- Produktų Sekcija -->\n    <section class=\"products-section\">\n        <h2 class=\"section-title\">Karštos Prekės</h2>\n        <div class=\"grid\">\n            \n            <!-- Produkto kortelė 1 -->\n            <div class=\"card\">\n                <img src=\"https://images.unsplash.com/photo-1509198397868-475647b2a1e5?auto=format&fit=crop&w=500&q=80\" alt=\"Cyberpunk Akiniai\">\n                <h3>Neon HUD Akiniai</h3>\n                <div class=\"price\">49.99 €</div>\n                <button class=\"neon-btn\" style=\"width: 100%; font-size: 1rem;\">Į krepšelį</button>\n            </div>\n\n            <!-- Produkto kortelė 2 -->\n            <div class=\"card\">\n                <img src=\"https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=500&q=80\" alt=\"RGB Batai\">\n                <h3>RGB Drive Kedai</h3>\n                <div class=\"price\">129.99 €</div>\n                <button class=\"neon-btn\" style=\"width: 100%; font-size: 1rem;\">Į krepšelį</button>\n            </div>\n\n            <!-- Produkto kortelė 3 -->\n            <div class=\"card\">\n                <img src=\"https://images.unsplash.com/photo-1555664424-778a1e5e1b48?auto=format&fit=crop&w=500&q=80\" alt=\"Klaviatūra\">\n                <h3>Cyber-Glow Striukė</h3>\n                <div class=\"price\">89.99 €</div>\n                <button class=\"neon-btn\" style=\"width: 100%; font-size: 1rem;\">Į krepšelį</button>\n            </div>\n\n        </div>\n    </section>\n\n    <!-- 3D Neoninio tinklo (Grid) generavimas fone -->\n    <script>\n        const container = document.getElementById('canvas-container');\n        const scene = new THREE.Scene();\n        \n        // Kamera\n        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);\n        camera.position.set(0, 20, 100);\n        camera.lookAt(0, 5, 0);\n\n        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });\n        renderer.setSize(window.innerWidth, window.innerHeight);\n        container.appendChild(renderer.domElement);\n\n        // Sukuriame Synthwave / Cyberpunk 3D tinklelį (Grid)\n        const size = 500;\n        const divisions = 50;\n        const gridHelper = new THREE.GridHelper(size, divisions, 0xff007f, 0x00f3ff);\n        gridHelper.position.y = -10;\n        scene.add(gridHelper);\n\n        // Apšvietimas fone (RGB dvelksmas)\n        const ambientLight = new THREE.AmbientLight(0x111111);\n        scene.add(ambientLight);\n\n        const directionalLight = new THREE.DirectionalLight(0x00f3ff, 1);\n        directionalLight.position.set(0, 1, 0);\n        scene.add(directionalLight);\n\n        // Animacija (Imituojame judėjimą / važiavimą keliu)\n        function animate() {\n            requestAnimationFrame(animate);\n\n            // Judina tinklelio linijas link kameros, sukuriant važiavimo efektą\n            gridHelper.position.z += 0.5;\n            if (gridHelper.position.z > (size / divisions)) {\n                gridHelper.position.z = 0;\n            }\n\n            renderer.render(scene, camera);\n        }\n\n        // Prisitaikymas prie ekrano dydžio keitimo\n        window.addEventListener('resize', onWindowResize, false);\n        function onWindowResize() {\n            camera.aspect = window.innerWidth / window.innerHeight;\n            camera.updateProjectionMatrix();\n            renderer.setSize(window.innerWidth, window.innerHeight);\n        }\n\n        animate();\n    </script>\n</body>\n</html>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
