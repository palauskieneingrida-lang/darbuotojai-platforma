<div class="cyber-marquee-wrapper">
  <div class="cyber-marquee-inner">
    <div class="cyber-marquee-track">
      <span>⚡ LEDONAS RGB FUTURE LIGHTS ⚡</span>
      <span>• JUDANTYS LED užrašai VERSLUI •</span>
      <span>⚡ NEONINIAI PAVEIKSLAI IR IDĖJOS ⚡</span>
      <span>• CHAMELEON RGB TECH •</span>
      
      <span>⚡ LEDONAS RGB FUTURE LIGHTS ⚡</span>
      <span>• JUDANTYS LED užrašai VERSLUI •</span>
      <span>⚡ NEONINIAI PAVEIKSLAI IR IDĖJOS ⚡</span>
      <span>• CHAMELEON RGB TECH •</span>
    </div>
  </div>
</div>

<style>
.cyber-marquee-wrapper {
  background: #000000 !important;
  padding: 20px 0;
  overflow: hidden;
  border-top: 2px solid #00f0ff;
  border-bottom: 2px solid #ff0055;
  box-shadow: 0 0 15px rgba(0, 240, 255, 0.3), inset 0 0 15px rgba(255, 0, 85, 0.2);
  perspective: 800px; /* Sukuriame 3D erdvę */
  margin: 30px 0;
}

.cyber-marquee-inner {
  /* Pasukame visą juostą 3D kampu, kad atrodytų kaip futuristinis holografinis projektorius */
  transform: rotateX(15deg) rotateY(-5deg) rotateZ(-1deg);
  transform-style: preserve-3d;
}

.cyber-marquee-track {
  display: flex;
  width: max-content;
  animation: scrollMarquee 20s linear infinite;
}

.cyber-marquee-track span {
  font-family: 'Courier New', Courier, monospace !important;
  font-size: 2.5rem;
  font-weight: 900;
  color: #00f0ff;
  white-space: nowrap;
  padding: 0 40px;
  text-transform: uppercase;
  letter-spacing: 3px;
  text-shadow: 0 0 10px #00f0ff, 0 0 20px rgba(0, 240, 255, 0.5);
}

/* Kas antras tekstas nusidažo rožine spalva */
.cyber-marquee-track span:nth-child(even) {
  color: #ff0055;
  text-shadow: 0 0 10px #ff0055, 0 0 20px rgba(255, 0, 85, 0.5);
}

/* Begalinio bėgimo animacija */
@keyframes scrollMarquee {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(-50%, 0, 0);
  }
}
</style>

